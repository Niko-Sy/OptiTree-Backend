# OptiTree Backend — 环境变量模板
# 复制为 .env 后按需修改，.env 已加入 .gitignore，不会被提交

# ── 外部 PostgreSQL（分布式数据库，直连远程服务器）────────────────────────────
DB_HOST=                # 数据库服务器 IP
DB_PORT=
DB_USER=
DB_PASSWORD=           # ⚠️ 生产环境请确认密码安全性
DB_NAME=

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_PASSWORD=optitree_redis          # ⚠️ 生产环境请使用强密码
REDIS_PORT=6379                        # 宿主机映射端口

# ── App ─────────────────────────────────────────────────────────────────────
APP_PORT=8080
APP_MODE=release                       # release | debug

# ── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=   # ⚠️ 必须修改！

# ── 存储 ─────────────────────────────────────────────────────────────────────
# 如部署在公网，将 localhost 替换为实际 IP 或域名
STORAGE_BASE_URL=http://localhost:8080/static
